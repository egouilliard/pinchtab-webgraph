{
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": [
        "localhost",
        "127.0.0.1",
        "github.com",
        "*.githubusercontent.com",
        "pypi.org",
        "files.pythonhosted.org"
      ]
    },
    "credentials": {
      "files": [
        { "path": "~/.ssh", "mode": "deny" },
        { "path": "~/.aws", "mode": "deny" },
        { "path": "~/.config/gcloud", "mode": "deny" },
        { "path": "~/.gnupg", "mode": "deny" }
      ]
    },
    "excludedCommands": ["docker"]
  }
}
