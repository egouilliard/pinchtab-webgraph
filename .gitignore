# secrets & runtime state — NEVER commit
# crawl-config.json holds the bridge auth token; .instance/ holds live sessions
# login-config.json holds per-host login routing (password stays in the OS keyring)
crawl-config.json
login-config.json
.instance/
bridge*.log
httpd.log
*.crawl.log

# Claude Code local sandbox/permission overrides (per-machine; committed settings.json is shared)
.claude/settings.local.json

# python
__pycache__/
*.pyc

# generated outputs (graphs, how-tos, screenshots, benchmarks, logs) — the tools
# default their --out here, so a normal run never litters the repo root.
out/

# ...the loose-in-root patterns below stay as a backstop for tools/scripts that
# still write to the working directory instead of out/.
*.html
# ...but DO track the packaged web-UI static assets (shipped in the wheel)
!pinchtab_webgraph/ui/static/*.html
# ...and the hand-authored e2e HTML fixtures (inputs to the crawl smoke test)
!tests/e2e/*.html
*.png
*.output
leytongo-*.json
books.json
webgraph.json
howto-*.json
recipe.json
recipe-*.json
bench-*.json
_settletest.*

# interaction-graph caches + test outputs
interaction-graph*.json
*-cache.json
test-*.json
cmp.json

# per-host cache-store files (ask.py write-back) — runtime data, never commit
caches/

# teams generality-test bridge (token + live session) + its generated outputs
teams-config.json
.instance-teams/
teams-*.log
teams-*.json
teams-*.md
teams-ui-map.md

# scratch test outputs
scratch-*

# python build artifacts
*.egg-info/
build/
dist/

# local AI-tooling artifacts (generated by gitnexus / editors — not project files)
/AGENTS.md
/CLAUDE.md
.claude/skills/
.gitnexus/
