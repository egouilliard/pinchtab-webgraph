{
  "meta": {
    "root": "http://acme.test/index.html",
    "note": "Models a real crawl of a site with TWO download links on the SAME page plus two create-forms. Two downloads is the case that exposes goal->trigger misrouting: both labels share the word 'download', both sit on the same state (identical path length), so nothing but the NOUN can tell them apart."
  },
  "states": [
    {"id": "s0", "url": "http://acme.test/index.html", "label": "/index.html", "depth": 0},
    {"id": "s1", "url": "http://acme.test/reports.html", "label": "Reports", "depth": 1},
    {"id": "s2", "url": "http://acme.test/documents.html", "label": "Documents", "depth": 1},
    {"id": "s3", "url": "http://acme.test/teams.html", "label": "Teams", "depth": 1}
  ],
  "state_index": {
    "http://acme.test/index.html": "s0",
    "http://acme.test/reports.html": "s1",
    "http://acme.test/documents.html": "s2",
    "http://acme.test/teams.html": "s3"
  },
  "edges": [
    {"from": "s0", "to": "s1", "label": "Reports", "selector": "nav>a:nth-of-type(1)", "kind": "link"},
    {"from": "s0", "to": "s2", "label": "Documents", "selector": "nav>a:nth-of-type(2)", "kind": "link"},
    {"from": "s0", "to": "s3", "label": "Teams", "selector": "nav>a:nth-of-type(3)", "kind": "link"}
  ],
