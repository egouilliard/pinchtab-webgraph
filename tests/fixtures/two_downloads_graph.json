      "form": null,
      "opensAt": null,
      "kind": "download",
      "selector": "#q3",
      "href": "http://acme.test/files/q3-report.pdf",
      "accept": null
    },
    {
      "label": "Download the logo",
      "state": "s1",
      "path": [{"label": "Reports", "selector": "nav>a:nth-of-type(1)", "href": "http://acme.test/reports.html"}],
      "form": null,
      "opensAt": null,
